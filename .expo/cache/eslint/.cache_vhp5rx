string;\r\n  date: string;\r\n  amount: string;\r\n  status: TxStatus;\r\n};\r\n\r\ntype TxSection = {\r\n  title: string;\r\n  data: Tx[];\r\n};\r\n\r\nconst TRANSACTIONS: TxSection[] = [\r\n  {\r\n    title: 'MAY 2026',\r\n    data: [\r\n      {\r\n        id: '1',\r\n        type: 'topup',\r\n        title: 'Wallet Top-up',\r\n        date: 'May 28, 2026 • 11:20 AM',\r\n        amount: '₦12,000.00',\r\n        status: 'PENDING',\r\n      },\r\n      {\r\n        id: '2',\r\n        type: 'token',\r\n        title: 'Ikeja Electric •\\n45151438822',\r\n        date: 'May 24, 2026 • 09:42 AM',\r\n        amount: '-₦5,000',\r\n        status: 'SUCCESSFUL',\r\n      },\r\n    ],\r\n  },\r\n  {\r\n    title: 'APRIL 2026',\r\n    data: [\r\n      {\r\n        id: '3',\r\n        type: 'topup',\r\n        title: 'Wallet Top-up',\r\n        date: 'April 28, 2026 • 11:20 AM',\r\n        amount: '+₦20,000',\r\n        status: 'SUCCESSFUL',\r\n      },\r\n      {\r\n        id: '4',\r\n        type: 'token',\r\n        title: 'Ibadan Electricity •\\n99002233114',\r\n        date: 'April 05, 2026 • 08:00 AM',\r\n        amount: '₦5,500.00',\r\n        status: 'FAILED',\r\n      },\r\n    ],\r\n  },\r\n];",{"desc":"875","fix":"912"},"removeUnusedImportDeclaration",{"varName":"913"},{"range":"914","text":"817"},"Remove unused import declaration.","Update the dependencies array to be: [focusAnim, isFocused]",{"range":"915","text":"916"},"removeUnusedVar",{"varName":"917"},{"range":"918","text":"817"},"Remove unused variable \"G\".",{"varName":"919"},{"range":"920","text":"817"},"Remove unused variable \"Line\".",{"varName":"921"},{"range":"922","text":"817"},"Remove unused variable \"PS_600\".",{"range":"923","text":"916"},{"varName":"924"},{"range":"925","text":"817"},{"range":"926","text":"916"},{"range":"927","text":"916"},"Update the dependencies array to be: [depositFocusAnim, depositFocused]",{"range":"928","text":"929"},{"varName":"930"},{"range":"931","text":"817"},"Remo